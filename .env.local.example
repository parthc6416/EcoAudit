# Copy this file to .env.local and fill in the values from your Supabase project
# (Supabase Dashboard -> Project Settings -> API)

# Your project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=your-project-url

# The "anon" / public API key. Safe to expose in the browser because
# Row Level Security (RLS) policies (see supabase/schema.sql) govern access.
# Do NOT use the service_role key here.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
